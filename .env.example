# Host port for the web app.
HOST_PORT=8794

# Maximum upload size accepted by the API/UI.
MAX_UPLOAD_MB=64

# Maximum batch size accepted by the API/UI.
MAX_BATCH_FILES=100
MAX_BATCH_TOTAL_MB=512

# Maximum input side and maximum generated output side, in pixels.
# 16384 = 16K x 16K.
MAX_IMAGE_DIMENSION=16384

# Number of saved output jobs shown/kept in local Docker storage.
HISTORY_LIMIT=100

# Number of queued single-image job records shown/kept in Redis.
QUEUE_HISTORY_LIMIT=100

# Number of saved batch records shown/kept in local Docker storage.
BATCH_HISTORY_LIMIT=50

# Redis/RQ queue settings. Defaults work with the included Compose files.
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=image-jobs
WORKER_CONCURRENCY=1
JOB_TIMEOUT_SECONDS=7200

# Runtime selection:
# - auto: use CUDA when available in the selected image/container, otherwise CPU
# - cpu: force CPU
# - cuda: require NVIDIA CUDA
UPSCALER_DEVICE=auto
REMBG_DEVICE=auto

# For docker-compose.prebuilt.yml, set this to your published image.
# Examples:
# CLARITY_IMAGE=ghcr.io/addison16/imagine-clarity:cpu
# CLARITY_IMAGE=ghcr.io/addison16/imagine-clarity:gpu
CLARITY_IMAGE=ghcr.io/addison16/imagine-clarity:cpu

# Optional local tag used by docker-compose.gpu.yml when building from source.
CLARITY_GPU_IMAGE=clarity-image-tools:gpu
