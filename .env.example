# Host port for the web app.
HOST_PORT=8794

# Maximum upload size accepted by the API/UI.
MAX_UPLOAD_MB=64

# Maximum input side and maximum generated output side, in pixels.
# 16384 = 16K x 16K.
MAX_IMAGE_DIMENSION=16384

# Runtime selection:
# - auto: use CUDA when available in the selected image/container, otherwise CPU
# - cpu: force CPU
# - cuda: require NVIDIA CUDA
UPSCALER_DEVICE=auto
REMBG_DEVICE=auto

# For docker-compose.prebuilt.yml, set this to your published image.
# Examples:
# CLARITY_IMAGE=ghcr.io/addison16/imagine-clarity:cpu
# CLARITY_IMAGE=ghcr.io/addison16/imagine-clarity:gpu
CLARITY_IMAGE=ghcr.io/addison16/imagine-clarity:cpu

# Optional local tag used by docker-compose.gpu.yml when building from source.
CLARITY_GPU_IMAGE=clarity-image-tools:gpu
